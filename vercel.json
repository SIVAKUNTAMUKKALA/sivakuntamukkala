{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/generate/groq",
      "dest": "/server.js"
    },
    {
      "src": "/generate/gemini",
      "dest": "/server.js"
    },
    {
      "src": "/usage",
      "dest": "/server.js"
    },
    {
      "src": "/testgen",
      "dest": "/server.js"
    },
    {
      "src": "/testgen/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/config",
      "dest": "/server.js"
    },
    {
      "src": "/create-subscription",
      "dest": "/server.js"
    },
    {
      "src": "/verify-payment",
      "dest": "/server.js"
    },
    {
      "src": "/cancel-subscription",
      "dest": "/server.js"
    },
    {
      "src": "/admin/stats",
      "dest": "/server.js"
    },
    {
      "src": "/admin",
      "dest": "/server.js"
    }
  ]
}
